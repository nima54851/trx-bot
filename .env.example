# 环境变量示例
# 复制为 .env 并填入真实值

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# TRON 网络
TRON_API_KEY=your_trongrid_api_key_here
TRON_NETWORK=mainnet  # mainnet / nile / shasta
TRON_WALLET_PRIVATE_KEY=your_private_key_here
TRON_WALLET_ADDRESS=your_tron_address_here

# 数据库
DATABASE_URL=postgresql://trxbot:trxbotpass@postgres:5432/trxbot

# Redis
REDIS_URL=redis://redis:6379/0

# 能量定价 (TRX per 1000 energy per day)
ENERGY_PRICE_PER_DAY=0.5

# 管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# 后端地址（Bot用）
BACKEND_URL=http://backend:8000

# 安全
SECRET_KEY=generate_a_random_secret_key_here
